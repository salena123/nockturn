{
    email {$ACME_EMAIL}
}

{$DOMAIN} {
    encode gzip zstd

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /vk/* {
        reverse_proxy messenger-bot:8010
    }

    handle /bot-health {
        rewrite * /health
        reverse_proxy messenger-bot:8010
    }

    handle /backend-health {
        rewrite * /health
        reverse_proxy backend:8000
    }

    handle {
        reverse_proxy crm-frontend:80
    }
}
